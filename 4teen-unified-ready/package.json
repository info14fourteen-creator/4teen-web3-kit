{
  "name": "@4teen/unified",
  "version": "0.1.0",
  "description": "Unified TRON wallet kit and reusable widgets for the 4TEEN ecosystem.",
  "type": "module",
  "main": "./dist/4teen-unified.umd.js",
  "module": "./dist/4teen-unified.es.js",
  "exports": {
    ".": {
      "import": "./dist/4teen-unified.es.js",
      "require": "./dist/4teen-unified.umd.js",
      "default": "./dist/4teen-unified.umd.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "clean": "rm -rf dist"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/info14fourteen-creator/4teen-unified.git"
  },
  "homepage": "https://github.com/info14fourteen-creator/4teen-unified",
  "bugs": {
    "url": "https://github.com/info14fourteen-creator/4teen-unified/issues"
  },
  "keywords": [
    "4teen",
    "tron",
    "tronlink",
    "wallet",
    "web3",
    "widgets",
    "dapp"
  ],
  "author": "4TEEN",
  "license": "MIT",
  "dependencies": {
    "buffer": "^6.0.3",
    "tronweb": "^6.0.4"
  },
  "devDependencies": {
    "vite": "^5.4.10"
  }
}
